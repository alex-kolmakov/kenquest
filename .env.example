# ── LLM Configuration ─────────────────────────────────────────────────────────
# Set LLM_MODEL to any LiteLLM-supported model string.
# Examples:
#   openai/gpt-4o-mini           (OpenAI — requires LLM_API_KEY)
#   gemini/gemini-2.0-flash      (Google AI Studio — requires GEMINI_API_KEY)
#   anthropic/claude-3-5-haiku   (Anthropic — requires ANTHROPIC_API_KEY)
#   ollama/llama3.2              (Ollama — no key needed, set OLLAMA_API_BASE)

LLM_MODEL=gemini/gemini-2.0-flash
LLM_API_KEY=

# Provider-specific keys (only set the one you use)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama (if using local models)
# OLLAMA_API_BASE=http://host.docker.internal:11434

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── Advanced (usually no need to change) ─────────────────────────────────────
# DATABASE_PATH=/app/data/kenquest.duckdb
# GRAPH_PATH=/app/data/graph
# CHROMA_PATH=/app/data/chroma
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# MAX_CONCEPTS=50
# MASTERY_THRESHOLD=0.7
